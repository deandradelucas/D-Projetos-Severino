      },
      "id": "b2c3d4e5-1002-4002-9002-000000000002",
      "name": "Processar lembretes no Horizonte",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "jsCode": "const mensagens = $json.mensagens || [];\nreturn mensagens.map((item) => ({\n  json: {\n    phone: item.phone,\n    message: item.message,\n    reminder_id: item.reminder_id,\n    event_id: item.event_id,\n    title: item.title,\n  }\n}));"
      },
      "id": "b2c3d4e5-1003-4003-9003-000000000003",
      "name": "Explodir mensagens",
      "type": "n8n-nodes-base.code",
