# Copie para .env ou .env.local (nunca commite segredos).
#
# API (produção)
# - Vercel mesmo projeto: não precisa; /api segue rewrites.
#
# Hostinger — front estático + API na Vercel (recomendado):
# No build Git: VITE_SEVERINO_API_ORIGIN=https://teu-projeto.vercel.app
# (sem barra final; sem /api)
#
# Hostinger — API na mesma VPS (proxy /api):
# VITE_SEVERINO_SAME_ORIGIN_API=1
#
# Outro host de API:
# VITE_SEVERINO_API_ORIGIN=https://api.seudominio.com
#
# api.severino.mestredamente.com sem DNS no bundle: o app Severino ignora e usa /api na mesma origem (ex.: Vercel).
# Só depois de criares DNS+CNAME na Vercel para api.severino…: VITE_SEVERINO_ALLOW_LEGACY_API_SUBDOMAIN=1
# NÃO use só Git estático sem proxy /api nem sem B — o login não funciona.
#
# VITE_SEVERINO_SAME_ORIGIN_API=1
# VITE_SEVERINO_API_ORIGIN=https://api.seudominio.com
# Front noutro hostname (opcional, vírgula para vários): VITE_SEVERINO_FRONT_HOST=app.severino.mestredamente.com
# Links de convite familiar / mensagem PWA: em localhost usam severino.mestredamente.com; para forçar outro host:
# VITE_PUBLIC_APP_ORIGIN=https://severino.mestredamente.com
# (opcional) VITE_API_ABSOLUTE=1
#
# Supabase — URL e chave anon vêm do painel: Settings → API
VITE_SUPABASE_URL=
# Opcional no servidor (Vercel/API): se não quiser duplicar VITE_*, use só esta; o cliente admin usa VITE_SUPABASE_URL || SUPABASE_URL
# SUPABASE_URL=
# Chave pública (anon) — usada pelo front (cadastro etc.)
VITE_SUPABASE_KEY=
# Service role — só no servidor (API Node / Vercel). Nunca exponha no front.
SUPABASE_SERVICE_ROLE_KEY=

# Asaas (servidor) — API key do mesmo ambiente (produção vs sandbox) dos pagamentos no painel.
# ASAAS_API_BASE_URL=https://api.asaas.com/v3   (sandbox: https://api-sandbox.asaas.com/v3)
# Sem '=' no início da URL (colagem de Excel quebra o fetch).
ASAAS_API_KEY=
# Origem da página de checkout (geralmente https://www.asaas.com ou sandbox)
# ASAAS_CHECKOUT_ORIGIN=https://www.asaas.com
# Portal “minha conta” mostrado ao utilizador (opcional)
# ASAAS_URL_MINHA_CONTA=https://www.asaas.com
# Token opcional na URL do webhook: /api/pagamentos/webhook?token=...
# ASAAS_WEBHOOK_TOKEN=
#
# Webhooks no painel Asaas — marque cobrança + assinatura para o mesmo endpoint POST acima.
# Cobrança (ex.): PAYMENT_CREATED, PAYMENT_CONFIRMED, PAYMENT_RECEIVED, PAYMENT_OVERDUE,
#   PAYMENT_REFUNDED, PAYMENT_UPDATED
# Assinatura (ex.): SUBSCRIPTION_CREATED, SUBSCRIPTION_UPDATED, SUBSCRIPTION_INACTIVATED,
#   SUBSCRIPTION_DELETED
# Lista atualizada também em GET /api/admin/pagamentos-saude (campo eventos_recomendados_asaas).
#
# Chave Asaas começa com $ — em .env use aspas para não ser truncada: ASAAS_API_KEY="$aact_..."
#
# Origem do front onde o utilizador volta após o checkout (só scheme+host, sem /api/...).
APP_BASE_URL=https://severino.mestredamente.com

# Preços dos planos (servidor define o valor; o cliente escolhe mensal vs anual).
# Com Stripe configurado: mensal = cartão só Stripe; anual = Pix no Asaas + cartão no Stripe (precisa dos dois gateways).
# Sem Stripe: Asaas cobre mensal (cartão) e anual (Pix + cartão).
HORIZONTE_PLANO_PRECO=10
HORIZONTE_PLANO_PRECO_ANUAL=100
# Prazo de vencimento (dias) da cobrança Pix avulsa gerada pelo QR na app (não é o checkout de assinatura).
# HORIZONTE_PIX_VENCIMENTO_DIAS=7

# Stripe — assinatura com cartão (Checkout hospedado pela Stripe; SAQ A no vosso lado).
# Webhook POST: /api/pagamentos/stripe/webhook (mesma origem da API; raw body para assinatura Stripe-Signature).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Opcional (Elements no futuro): STRIPE_PUBLISHABLE_KEY=pk_test_...
# Opcional: preços criados no dashboard (senão usa price_data + HORIZONTE_PLANO_* em centavos)
# STRIPE_PRICE_ID_MONTHLY=
# STRIPE_PRICE_ID_YEARLY=

# Trial (dias)
HORIZONTE_TRIAL_DIAS=7

# Conta familiar — limite fixo no código: 5 pessoas (titular + até 4 vinculados). Validade do convite em dias (padrão 7):
# FAMILIA_CONVITE_DIAS=7

# Admin principal (rotas /api/admin/*)
SUPER_ADMIN_EMAIL=mestredamente@mestredamente.com

# Google Gemini — Severino IA (chat no app), interpretação de agenda e voz no WhatsApp (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
# Opcional: forçar um modelo (ex.: gemini-2.0-flash). Se vazio, tenta 2.5-flash → 2.0-flash → 1.5-flash.
# GEMINI_MODEL=gemini-2.0-flash

# CORS: origens extras separadas por vírgula (produção com front em outro domínio)
CORS_ORIGINS=

# n8n — URL da instância usada para workflows externos (lembretes da Agenda, automações).
# Evolution → n8n → Severino: ver docs/whatsapp-evolution-n8n.md (webhook_by_events no n8n).
N8N_BASE_URL=https://n8n.mestredamente.com
N8N_API_KEY=

# WhatsApp — botão de contato no dashboard (opcional). Use link completo OU só o número (DDI+DDD+número, dígitos).
# VITE_WHATSAPP_LINK=https://wa.me/5511999998888?text=Ol%C3%A1
# VITE_WHATSAPP_PHONE=5511999998888
VITE_WHATSAPP_LINK=
VITE_WHATSAPP_PHONE=
# Mesmo contato só no servidor (Vercel / API): usado se VITE_* não estiver no bundle do front.
WHATSAPP_CONTACT_LINK=
WHATSAPP_CONTACT_PHONE=

# Bot WhatsApp — segredo compartilhado entre o backend e o workflow n8n.
# Gere um valor forte: openssl rand -hex 32
WHATSAPP_BOT_SECRET=

# Conversas pelo WhatsApp (não só lançamentos): Severino IA com contexto do utilizador — mesma GEMINI_API_KEY que o chat no app.

# Webhook WhatsApp (Telein/Evolution): token em ?token= ou /api/whatsapp/webhook/TOKEN. Notas de voz: transcrição via GEMINI_API_KEY.
# Obrigatório em produção (Vercel / NODE_ENV=production). Em desenvolvimento local, sem esta variável usa-se um fallback só para dev.
# WHATSAPP_WEBHOOK_TOKEN=
# Opcional: headers JSON extra para o GET do áudio (mmg.whatsapp.net / proxy). O servidor também envia o campo
# `apikey` do próprio webhook Evolution no pedido, se existir no JSON.
# WHATSAPP_MEDIA_FETCH_HEADERS={"Authorization":"Bearer ..."}

# Base publica que o gateway WhatsApp/Evolution usa para chamar o webhook.
# Em Docker Desktop local, host.docker.internal aponta do container para a API Node do host.
# Em producao, use a URL publica do app/API (ex.: https://severino.mestredamente.com).
WHATSAPP_WEBHOOK_BASE_URL=http://host.docker.internal:3001

# Evolution API local via Docker (docker-compose.yml)
# Troque EVOLUTION_API_KEY antes de expor a Evolution fora da sua maquina.
EVOLUTION_API_KEY=change-me-local-evolution-key
# Nome da instância Evolution (envio de texto: lembretes, bot, código de redefinição de senha).
# EVOLUTION_INSTANCE=minha-instancia
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_PORT=8080
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_SESSION_PHONE_CLIENT=Severino
EVOLUTION_SESSION_PHONE_NAME=Chrome
EVOLUTION_SESSION_PHONE_VERSION=2.3000.1035194821
EVOLUTION_QRCODE_LIMIT=60
EVOLUTION_POSTGRES_DB=evolution
EVOLUTION_POSTGRES_PASSWORD=evol_secret
EVOLUTION_DATABASE_CLIENT_NAME=severino_evolution

# Opcional: segredo extra no hash do código OTP de redefinição de senha (WhatsApp).
# PASSWORD_OTP_PEPPER=

# E-mail transacional — OTP de verificação de cadastro (nodemailer).
# Hostinger: smtp.hostinger.com porta 465 (SSL) ou 587 (TLS).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=mestredamente@mestredamente.com
SMTP_PASS=
# Opcional (padrão: "Severino <SMTP_USER>"):
# SMTP_FROM=Severino <mestredamente@mestredamente.com>
