{
  "name": "horizonte-financeiro",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:api": "node server/index.mjs",
    "build": "vite build",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test": "npm run test:unit && npm run lint && npm run build",
    "ci": "npm run test:unit && npm run lint && npm run build && npm run audit:dashboard-css && npm run audit:important-budget",
    "audit:important-budget": "node scripts/check-important-budget.mjs",
    "audit:dashboard-css": "node scripts/find-unused-dashboard-css.mjs",
    "audit:orphan-exports": "node scripts/audit-orphan-exports.mjs",
    "audit:orphan-files": "node scripts/audit-orphan-files.mjs",
    "audit:orphan-endpoints": "node scripts/audit-orphan-endpoints.mjs",
    "audit:orphan-assets": "node scripts/audit-orphan-assets.mjs",
    "strip:dashboard-theme-css": "node scripts/strip-non-light-theme-css.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "whatsapp:docker:up": "docker compose up -d",
    "whatsapp:docker:logs": "docker compose logs -f evolution-api",
    "whatsapp:docker:down": "docker compose down",
    "supabase:check": "node scripts/supabase-admin-check.mjs",
    "backup:rclone": "node scripts/run-rclone-backup.mjs",
    "backup:rclone:task": "powershell -ExecutionPolicy Bypass -File scripts/install-rclone-backup-task.ps1",
    "n8n:push": "node scripts/push-n8n-whatsapp-bot-workflow.mjs",
    "check:gemini": "node scripts/check-gemini-api.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@hono/node-server": "^1.19.14",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supabase/supabase-js": "^2.106.2",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.4.3",
    "hono": "^4.12.23",
    "ioredis": "^5.10.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.14",
    "vitest": "^3.2.4"
  }
}
